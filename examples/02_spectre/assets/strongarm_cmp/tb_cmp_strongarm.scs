    M1 (VP1 VINN VS VSS) nch_ulvt_mac l=30n w=16.0u multi=1 nf=32 sd=100n \
        ad=8e-13 as=9.55e-13 pd=19.2u ps=20.82u nrd=0.034712 nrs=0.034712 \
        sa=1.24563u sb=1.24563u sa1=581.909n sa2=955.685n sa3=1.05624u \
        sa4=1.22761u sb1=581.909n sb2=955.685n sb3=1.05624u spa=100n \

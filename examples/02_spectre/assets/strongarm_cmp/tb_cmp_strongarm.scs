// StrongArm Dynamic Comparator — SAR ADC Testbench
// Process  : TSMC 28nm HPC+ (CRN28HPC+ULL)
// VDD      : 0.9 V   Vcm : 0.45 V (= VDD/2)   Vid : 1 mV
// CLK rate : 1 GHz   Preset: conservative
// Design targets:  Tcmp < 50 ps,  Input-referred noise < 400 µV rms
//
// StrongArm topology (4-phase operation)
// ─────────────────────────────────────────────────────────────────
//  RESET  (CLK=0) : PMOS reset pull VP1/VN1/LP/LM → VDD
//                   M79 (source=LM, drain=LP) equalises latch nodes
//  INTEGRATION    : CLK rises, tail M88 turns on; M0/M1 discharge
//                   VN1 faster if VINP>VINN (more Vgs → more Id)
//  REGENERATION   : NMOS latch M45/M6 + PMOS latch M48/M49 kick in;
//                   LP/LM race to VDD/0 with time-constant τ = C/gm
//  OUTPUT BUFFER  : Double inverter per rail: LP → net1 → DCMPP
//                                             LM → net2 → DCMPN
//
// Transistor mapping:
//   VS              tail node (source of M0 & M1)
//   VP1             drain of M1 (VINN input transistor)
//   VN1             drain of M0 (VINP input transistor)
//   LP, LM          differential latch nodes (observable at top level)
//   DCMPP, DCMPN    buffered digital outputs
//   net1 = inv(LM)  intermediate buffer node
//   net2 = inv(LP)  intermediate buffer node
// ─────────────────────────────────────────────────────────────────
simulator lang=spectre
global 0
parameters VDD=0.9 Vcm=0.45 Vid=1m f=1G
include "@@VB_PDK_SPECTRE_TOPLEVEL@@" section=TOP_TT

// ── Subcircuit ─────────────────────────────────────────────────────────────
// Identical transistors to tb_cmp_pss_pnoise.scs (original Virtuoso export)
// No layout-parameter changes; proven-good in Spectre.
subckt CMP_BUFF CLK DCMPN DCMPP LM LP VDD VINN VINP VSS
    M88 (VS CLK VSS VSS) nch_ulvt_mac l=30n w=2u multi=1 nf=4 sd=100n \
        ad=1e-13 as=1.5e-13 pd=2.4u ps=3.6u nrd=0.229097 nrs=0.229097 \
        sa=344.542n sb=344.542n sa1=294.801n sa2=336.962n sa3=409.667n \
        sa4=342.239n sb1=294.801n sb2=336.962n sb3=409.667n spa=100n \
        spa1=100n spa2=100n spa3=100n sap=151.977n sapb=166.788n \
        spba=115.715n spba1=117.043n dfm_flag=0 spmt=1.11111e+15 spomt=0 \
        spomt1=1.11111e+60 spmb=1.11111e+15 spomb=0 spomb1=1.11111e+60
    M10 (net1 LM VSS VSS) nch_ulvt_mac l=30n w=500n multi=1 nf=1 sd=100n \
        ad=5e-14 as=5e-14 pd=1.2u ps=1.2u nrd=0.572742 nrs=0.572742 \
        sa=205.00n sb=205.00n sa1=205.00n sa2=205.00n sa3=205.00n \
        sa4=205.00n sb1=205.00n sb2=205.00n sb3=205.00n spa=100n spa1=100n \
        spa2=100n spa3=100n sap=128.203n sapb=146.81n spba=115.715n \
        spba1=117.043n dfm_flag=0 spmt=1.11111e+15 spomt=0 \
        spomt1=1.11111e+60 spmb=1.11111e+15 spomb=0 spomb1=1.11111e+60
    M16 (net2 LP VSS VSS) nch_ulvt_mac l=30n w=500n multi=1 nf=1 sd=100n \
        ad=5e-14 as=5e-14 pd=1.2u ps=1.2u nrd=0.572742 nrs=0.572742 \
        sa=205.00n sb=205.00n sa1=205.00n sa2=205.00n sa3=205.00n \
        sa4=205.00n sb1=205.00n sb2=205.00n sb3=205.00n spa=100n spa1=100n \
